{
  "name": "campusflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:clean": "npm run web:build:clean",
    "web:build:clean": "npm run build:clean -w @campusflow/web",
    "api:seed": "npm run seed --workspace=@campusflow/api --",
    "api:seed:data": "npm run seed:data --workspace=@campusflow/api --",
    "api:seed:roles": "npm run seed:roles --workspace=@campusflow/api --",
    "api:seed:maa": "npm run seed:maa --workspace=@campusflow/api --",
    "api:delete-tenant": "npm run delete-tenant --workspace=@campusflow/api --",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "cd packages/db && npx prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
