# ─── Super Admin ──────────────────────────────────────────────────────────────
SUPER_ADMIN_API_KEY=change-this-to-a-long-random-secret

# ─── Database (Neon — free tier) ──────────────────────────────────────────────
# Sign up at https://neon.tech → New Project → copy connection string
DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/campusflow?sslmode=require"

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# In development (NODE_ENV !== production), forgot-password skips email/SMS/Redis; use OTP 000000 on reset. Invites log URL only. Set AUTH_REQUIRE_OTP=1 to force real OTP + emails locally.
# AUTH_REQUIRE_OTP=1
# Never in real prod: SKIP_AUTH_EMAIL_OTP=1
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
# Used when creating users/students without an explicit password (min 8 characters).
DEFAULT_NEW_USER_PASSWORD=ChangeMe123!
# Shared demo password for `npm run api:seed:data`, `api:seed:roles`, `api:seed:maa` (min 8 characters).
# Default in code: Demo@123. Override per run with `--password=...` on those scripts.
# Tip: use the same value for `npm run api:seed -- ... --password=...` so your admin matches seeded users.
# SEED_DEMO_PASSWORD=Demo@123
# Standalone (one institute per deployment): set this to the same slug you used with
# `npm run api:seed -- --slug=...`. The API then resolves the tenant without subdomain
# headers. `api:seed`, `seed:maa`, `seed:data`, and `seed:roles` also use this when you
# omit `--slug=...`. If unset and the DB has exactly one tenant, that tenant is used.
# Re-run `npm run api:seed` with no args (only this set): touches the existing tenant
# (ensures GEN department) and does not create a new institute.
SINGLE_TENANT_SLUG=mish
# SINGLE_TENANT_ID=   (optional alternative to slug)
# Optional: extra allowed browser origins for CORS in production (comma-separated full URLs).
# Default production also allows *.campusflow.io, *.onrender.com, *.vercel.app, localhost.
# CORS_ORIGINS=https://your-frontend.onrender.com

# ─── App ──────────────────────────────────────────────────────────────────────
# Next.js loads this file from the repo root (see apps/web/next.config.ts) so Prisma routes in the web app
# see DATABASE_URL without duplicating it in apps/web/.env.local.
# Browser calls this host for API. Must be a public URL when the web app is on HTTPS (e.g. Render);
# never use http://localhost:4000 in production builds — browsers block public pages from calling loopback.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
# Optional: only if multiple tenants in one DB and you must pick one from the browser (tenant publicKey).
# NEXT_PUBLIC_TENANT_KEY=

# ─── Redis (Upstash — free tier) ──────────────────────────────────────────────
# Sign up at https://upstash.com → Create Database → copy REST URL + Token
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# Leave both blank in dev — OTPs will print to console instead

# ─── Email (Resend — free tier) ───────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create Key
# Free: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=MAA Education portal <noreply@campusflow.io>
# Leave blank in dev — emails will print to console instead

# ─── SMS (MSG91) ──────────────────────────────────────────────────────────────
# Leave blank in dev — OTPs print to console
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CAMPFL
MSG91_OTP_TEMPLATE_ID=

# ─── File Storage (Cloudflare R2 — free: 10 GB) ───────────────────────────────
# Sign up at https://cloudflare.com → R2 → Create Bucket
# Leave blank in dev — file uploads not wired yet
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=campusflow-uploads
R2_PUBLIC_URL=

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Zoom ─────────────────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
