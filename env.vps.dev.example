# ─── Copy to .env.dev on the VPS:  cp env.vps.dev.example .env.dev ───
#
# Dev stack (separate from prod .env). Do not reuse prod JWT_SECRET or API keys.
# After editing:
#   docker compose --env-file .env.dev \
#     -f docker-compose.yml -f docker-compose.dev-vps.yml build web
#   docker compose --env-file .env.dev \
#     -f docker-compose.yml -f docker-compose.dev-vps.yml up -d
#
# DNS: A record `dev` → same VPS IP as production.
# Nginx: docker/vps.nginx.single-host.dev.conf

# ─── Super Admin (HTTP header for super-admin routes) ───────────────────────
SUPER_ADMIN_API_KEY=REPLACE_WITH_LONG_RANDOM_STRING_DEV

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_DEV
JWT_EXPIRES_IN=7d
DEFAULT_NEW_USER_PASSWORD=Dev@123

# Slug for seed: docker compose --env-file .env.dev -f ... exec api node .../seed.js --slug=mish-dev
SINGLE_TENANT_SLUG=mish-dev

# Browser origin(s) for dev Next.js (HTTPS). Comma-separated, no spaces.
CORS_ORIGINS=https://dev.mish.org.in

# ─── Public URLs (must match DNS + Nginx + Certbot) ─────────────────────────
NEXT_PUBLIC_APP_DOMAIN=dev.mish.org.in

# Single-host: API proxied under /api/* on the same host as the web app.
NEXT_PUBLIC_API_URL=https://dev.mish.org.in

# ─── Redis (Upstash) — leave blank only if you accept OTP/email limits in dev mode ─
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Campusflow Dev <noreply@dev.mish.org.in>

# ─── SMS (MSG91) ──────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CAMPFL
MSG91_OTP_TEMPLATE_ID=

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=campusflow-uploads-dev
R2_PUBLIC_URL=

# ─── Razorpay / Zoom (optional) ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
