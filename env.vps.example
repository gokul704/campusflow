# ─── Copy to .env on the VPS:  cp env.vps.example .env   then replace YOURDOMAIN.com ───
# Dev stack on same VPS: cp env.vps.dev.example .env.dev — use docker-compose.dev-vps.yml (see that file).
#
# Docker: `docker-compose.yml` pins api+web to bundled Postgres — do not set Neon placeholders here.
# After editing:  export NEXT_PUBLIC_API_URL=... NEXT_PUBLIC_APP_DOMAIN=...
#                 docker compose -f docker-compose.yml -f docker-compose.vps.yml build web
#                 docker compose -f docker-compose.yml -f docker-compose.vps.yml up -d

# ─── Super Admin (HTTP header for super-admin routes) ───────────────────────
SUPER_ADMIN_API_KEY=REPLACE_WITH_LONG_RANDOM_STRING

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
DEFAULT_NEW_USER_PASSWORD=REPLACE_MIN_8_CHARS

# Same slug you used in: docker compose exec api node .../seed.js --slug=...
SINGLE_TENANT_SLUG=mish

# Browser origin(s) for your Next.js site (HTTPS). Comma-separated, no spaces.
CORS_ORIGINS=https://YOURDOMAIN.com,https://www.YOURDOMAIN.com

# ─── Public URLs (must match DNS + Nginx + Certbot) ─────────────────────────
# Frontend hostname (no https://) — what users see in the bar, e.g. YOURDOMAIN.com
NEXT_PUBLIC_APP_DOMAIN=YOURDOMAIN.com

# API base URL the browser calls (full origin, https in production):
#
# Option A — separate API host (DNS A record "api"):
#   NEXT_PUBLIC_API_URL=https://api.YOURDOMAIN.com
#   Use docker/vps.nginx.example.conf
#
# Option B — one domain only (no api.): API is proxied under the SAME host as /api/*
#   NEXT_PUBLIC_API_URL=https://YOURDOMAIN.com
#   Use docker/vps.nginx.single-host.conf (replace YOURDOMAIN.com in that file too)
NEXT_PUBLIC_API_URL=https://YOURDOMAIN.com

# ─── Redis (Upstash) — leave blank only if you accept OTP/email limits in dev mode ─
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=MAA Education portal <noreply@YOURDOMAIN.com>

# ─── SMS (MSG91) ──────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CAMPFL
MSG91_OTP_TEMPLATE_ID=

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=campusflow-uploads
R2_PUBLIC_URL=

# ─── Razorpay / Zoom (optional) ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
