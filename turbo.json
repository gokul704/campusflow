{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "SUPER_ADMIN_API_KEY",
        "PORT",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "DEFAULT_NEW_USER_PASSWORD",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "RESEND_API_KEY",
        "EMAIL_FROM",
        "APP_URL",
        "MSG91_AUTH_KEY",
        "MSG91_SENDER_ID",
        "MSG91_OTP_TEMPLATE_ID",
        "R2_ACCOUNT_ID",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET",
        "R2_PUBLIC_URL",
        "RAZORPAY_KEY_ID",
        "RAZORPAY_KEY_SECRET",
        "ZOOM_ACCOUNT_ID",
        "ZOOM_CLIENT_ID",
        "ZOOM_CLIENT_SECRET",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_APP_DOMAIN",
        "NEXT_PUBLIC_TENANT_KEY",
        "SINGLE_TENANT_SLUG",
        "SINGLE_TENANT_ID"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env.production.local",
        ".env.local",
        ".env.production",
        ".env"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    }
  }
}
