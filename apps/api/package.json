{
  "name": "@campusflow/api",
  "version": "1.0.0",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "npm run db:deploy --workspace=@campusflow/db && dotenv -e ../../.env -- tsx src/scripts/seed.ts",
    "seed:data": "npm run db:deploy --workspace=@campusflow/db && dotenv -e ../../.env -- tsx src/scripts/seed-data.ts",
    "seed:roles": "npm run db:deploy --workspace=@campusflow/db && dotenv -e ../../.env -- tsx src/scripts/seed-role-users.ts",
    "seed:maa": "npm run db:deploy --workspace=@campusflow/db && dotenv -e ../../.env -- tsx src/scripts/seed-maa.ts",
    "api:seed": "npm run seed --",
    "api:seed:data": "npm run seed:data --",
    "api:seed:roles": "npm run seed:roles --",
    "api:seed:maa": "npm run seed:maa --",
    "delete-tenant": "dotenv -e ../../.env -- tsx src/scripts/delete-tenant-by-slug.ts",
    "api:delete-tenant": "npm run delete-tenant --"
  },
  "dependencies": {
    "@campusflow/db": "*",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^11.0.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "resend": "^6.9.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
